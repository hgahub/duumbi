  "duumbi:exports": ["abs", "max", "min"],
  "duumbi:functions": [
    {
      "@type": "duumbi:Function",
      "@id": "duumbi:math/abs",
      "duumbi:name": "abs",
      "duumbi:returnType": "i64",
      "duumbi:params": [{"duumbi:name": "x", "duumbi:paramType": "i64"}],
      "duumbi:blocks": [
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:math/abs/entry",
          "duumbi:label": "entry",
          "duumbi:ops": [
            {"@type": "duumbi:Load", "@id": "duumbi:math/abs/entry/0",
              "duumbi:variable": "x", "duumbi:resultType": "i64"},
            {"@type": "duumbi:Const", "@id": "duumbi:math/abs/entry/1",
              "duumbi:value": 0, "duumbi:resultType": "i64"},
            {"@type": "duumbi:Compare", "@id": "duumbi:math/abs/entry/2",
              "duumbi:operator": "lt",
              "duumbi:left": {"@id": "duumbi:math/abs/entry/0"},
              "duumbi:right": {"@id": "duumbi:math/abs/entry/1"},
              "duumbi:resultType": "bool"},
            {"@type": "duumbi:Branch", "@id": "duumbi:math/abs/entry/3",
              "duumbi:condition": {"@id": "duumbi:math/abs/entry/2"},
              "duumbi:trueBlock": "abs_neg",
              "duumbi:falseBlock": "abs_pos"}
          ]
        },
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:math/abs/abs_neg",
          "duumbi:label": "abs_neg",
          "duumbi:ops": [
            {"@type": "duumbi:Const", "@id": "duumbi:math/abs/abs_neg/0",
              "duumbi:value": 0, "duumbi:resultType": "i64"},
            {"@type": "duumbi:Load", "@id": "duumbi:math/abs/abs_neg/1",
              "duumbi:variable": "x", "duumbi:resultType": "i64"},
            {"@type": "duumbi:Sub", "@id": "duumbi:math/abs/abs_neg/2",
              "duumbi:left": {"@id": "duumbi:math/abs/abs_neg/0"},
              "duumbi:right": {"@id": "duumbi:math/abs/abs_neg/1"},
              "duumbi:resultType": "i64"},
            {"@type": "duumbi:Return", "@id": "duumbi:math/abs/abs_neg/3",
              "duumbi:operand": {"@id": "duumbi:math/abs/abs_neg/2"}}
          ]
        },
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:math/abs/abs_pos",
          "duumbi:label": "abs_pos",
          "duumbi:ops": [
            {"@type": "duumbi:Load", "@id": "duumbi:math/abs/abs_pos/0",
              "duumbi:variable": "x", "duumbi:resultType": "i64"},
            {"@type": "duumbi:Return", "@id": "duumbi:math/abs/abs_pos/1",
              "duumbi:operand": {"@id": "duumbi:math/abs/abs_pos/0"}}
          ]
        }
      ]
    },
    {
