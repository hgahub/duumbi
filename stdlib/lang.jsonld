            {"@type": "duumbi:Branch", "@id": "duumbi:lang/assert_true/entry/1",
              "duumbi:condition": {"@id": "duumbi:lang/assert_true/entry/0"},
              "duumbi:trueBlock": "assert_pass",
              "duumbi:falseBlock": "assert_fail"}
          ]
        },
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:lang/assert_true/assert_pass",
