              "duumbi:value": 0, "duumbi:resultType": "i64"},
            {"@type": "duumbi:Return", "@id": "duumbi:lang/assert_true/assert_pass/1",
              "duumbi:operand": {"@id": "duumbi:lang/assert_true/assert_pass/0"}}
          ]
        },
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:lang/assert_true/assert_fail",
          "duumbi:label": "assert_fail",
          "duumbi:ops": [
            {"@type": "duumbi:Const", "@id": "duumbi:lang/assert_true/assert_fail/0",
              "duumbi:value": "assertion failed: expected true",
              "duumbi:resultType": "string"},
            {"@type": "duumbi:PrintString", "@id": "duumbi:lang/assert_true/assert_fail/1",
              "duumbi:operand": {"@id": "duumbi:lang/assert_true/assert_fail/0"}},
            {"@type": "duumbi:Const", "@id": "duumbi:lang/assert_true/assert_fail/2",
              "duumbi:value": 1, "duumbi:resultType": "i64"},
            {"@type": "duumbi:Return", "@id": "duumbi:lang/assert_true/assert_fail/3",
              "duumbi:operand": {"@id": "duumbi:lang/assert_true/assert_fail/2"}}
          ]
        }
      ]
    },
    {
      "@type": "duumbi:Function",
