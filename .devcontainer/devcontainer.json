{
    "name": "Duumbi Dev",
    "image": "mcr.microsoft.com/devcontainers/rust:1",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/copilot-cli:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24.15.0"
        },
        "ghcr.io/devcontainers-extra/features/claude-code:2": {},
        "ghcr.io/dirien/devcontainer-feature-codex/codex:0": {},
        "ghcr.io/devcontainers-extra/features/npm-package:1": {
            "package": "@augmentcode/auggie"
        },
        "ghcr.io/stu-bell/devcontainer-features/open-code:0": {},
        "ghcr.io/gvatsal60/dev-container-features/pre-commit:1": {},
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.14.4"
        }
    },
    "containerEnv": {
        "CARGO_TERM_COLOR": "always",
        "RUST_BACKTRACE": "1"
    },
    "mounts": [
        "source=duumbi-cargo-registry,target=/usr/local/cargo/registry,type=volume",
        "source=duumbi-cargo-git,target=/usr/local/cargo/git,type=volume",
        "source=duumbi-target,target=${containerWorkspaceFolder}/target,type=volume"
    ],
    "forwardPorts": [
        8421
    ],
    "portsAttributes": {
        "8421": {
            "label": "DUUMBI Studio"
        }
    },
    "postCreateCommand": "bash -l .devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "settings": {
                "rust-analyzer.check.command": "clippy",
                "rust-analyzer.cargo.allTargets": true
            },
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "ms-python.python",
                "vadimcn.vscode-lldb",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "serayuzgur.crates",
                "GitHub.vscode-github-actions"
            ]
        }
    }
}
