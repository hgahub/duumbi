# Tagger Module Configuration
# Azure AI Vision credentials
TAGGER_AZURE_VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
TAGGER_AZURE_VISION_KEY=your-azure-vision-api-key

# Image Size Constraints
TAGGER_MAX_IMAGE_SIZE_MB=10
TAGGER_MAX_IMAGE_WIDTH=4096
TAGGER_MAX_IMAGE_HEIGHT=4096
TAGGER_MIN_IMAGE_WIDTH=640
TAGGER_MIN_IMAGE_HEIGHT=480

# Quality Thresholds (0-10 scale)
TAGGER_MIN_QUALITY_SCORE=5.0
TAGGER_MIN_BRIGHTNESS_SCORE=4.0
TAGGER_MIN_SHARPNESS_SCORE=5.0

# Processing Configuration
TAGGER_TIMEOUT_SECONDS=30
TAGGER_MAX_RETRIES=3
TAGGER_RETRY_DELAY_SECONDS=1.0

# Batch Processing
TAGGER_MAX_BATCH_SIZE=20
TAGGER_BATCH_TIMEOUT_SECONDS=120

# Feature Detection Thresholds (0-1 scale)
TAGGER_ROOM_DETECTION_CONFIDENCE_THRESHOLD=0.6
TAGGER_FEATURE_DETECTION_CONFIDENCE_THRESHOLD=0.7
TAGGER_TAG_CONFIDENCE_THRESHOLD=0.5

