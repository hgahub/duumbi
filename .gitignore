# ── Rust ────────────────────────────────────────────────────────────────────
target/
# Cargo.lock is intentionally tracked (binary/application crate)

# ── DUUMBI workspace ────────────────────────────────────────────────────────
.duumbi/

# ── Compiled runtime shim ────────────────────────────────────────────────────
duumbi_runtime.o

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/settings.json
*.sublime-workspace

# ── Infra (Pulumi/Node.js) ───────────────────────────────────────────────────
infra/node_modules/
infra/bin/*.js
infra/bin/*.js.map
infra/bin/*.d.ts
infra/bin/*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Secrets / environment ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Caches ────────────────────────────────────────────────────────────────────
cache/

# ── Claude Code worktrees ────────────────────────────────────────────────────
.claude/worktrees/
.claude/*.lock
.claude/*.local.json

# ── Codex ────────────────────────────────────────────────────────────────────
.codex/

