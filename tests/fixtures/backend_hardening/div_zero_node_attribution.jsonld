{
  "@context": { "duumbi": "https://duumbi.dev/ns/core#" },
  "@type": "duumbi:Module",
  "@id": "duumbi:backend_hardening",
  "duumbi:name": "backend_hardening",
  "duumbi:functions": [
    {
      "@type": "duumbi:Function",
      "@id": "duumbi:backend_hardening/main",
      "duumbi:name": "main",
      "duumbi:returnType": "i64",
      "duumbi:blocks": [
        {
          "@type": "duumbi:Block",
          "@id": "duumbi:backend_hardening/main/entry",
          "duumbi:label": "entry",
          "duumbi:ops": [
            {
              "@type": "duumbi:Const",
              "@id": "duumbi:backend_hardening/main/entry/dividend",
              "duumbi:value": 10,
              "duumbi:resultType": "i64"
            },
            {
              "@type": "duumbi:Const",
              "@id": "duumbi:backend_hardening/main/entry/zero_divisor",
              "duumbi:value": 0,
              "duumbi:resultType": "i64"
            },
            {
              "@type": "duumbi:Div",
              "@id": "duumbi:backend_hardening/main/entry/div_zero",
              "duumbi:left": { "@id": "duumbi:backend_hardening/main/entry/dividend" },
              "duumbi:right": { "@id": "duumbi:backend_hardening/main/entry/zero_divisor" },
              "duumbi:resultType": "i64"
            },
            {
              "@type": "duumbi:Return",
              "@id": "duumbi:backend_hardening/main/entry/return",
              "duumbi:operand": { "@id": "duumbi:backend_hardening/main/entry/div_zero" }
            }
          ]
        }
      ]
    }
  ]
}
