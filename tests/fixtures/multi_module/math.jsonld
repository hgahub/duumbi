{
    "@context": {"duumbi": "https://duumbi.dev/ns/core#"},
    "@type": "duumbi:Module",
    "@id": "duumbi:math",
    "duumbi:name": "math",
    "duumbi:exports": ["double"],
    "duumbi:functions": [{
        "@type": "duumbi:Function",
        "@id": "duumbi:math/double",
        "duumbi:name": "double",
        "duumbi:returnType": "i64",
        "duumbi:params": [{"duumbi:name": "x", "duumbi:paramType": "i64"}],
        "duumbi:blocks": [{
            "@type": "duumbi:Block",
            "@id": "duumbi:math/double/entry",
            "duumbi:label": "entry",
            "duumbi:ops": [
                {"@type": "duumbi:Load", "@id": "duumbi:math/double/entry/0",
                  "duumbi:variable": "x", "duumbi:resultType": "i64"},
                {"@type": "duumbi:Load", "@id": "duumbi:math/double/entry/1",
                  "duumbi:variable": "x", "duumbi:resultType": "i64"},
                {"@type": "duumbi:Add", "@id": "duumbi:math/double/entry/2",
                  "duumbi:left": {"@id": "duumbi:math/double/entry/0"},
                  "duumbi:right": {"@id": "duumbi:math/double/entry/1"},
                  "duumbi:resultType": "i64"},
                {"@type": "duumbi:Return", "@id": "duumbi:math/double/entry/3",
                  "duumbi:operand": {"@id": "duumbi:math/double/entry/2"}}
            ]
        }]
    }]
}
