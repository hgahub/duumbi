# Duumbi Infrastructure - Justfile
# Run `just --list` to see all available commands

# Default recipe (shows help)
default:
    @just --list

# Install dependencies
install:
    @echo "📦 Installing dependencies..."
    npm install

# Setup all stacks (persistent + platform + staging)
setup: install
    @echo "🚀 Setting up Duumbi Infrastructure Stacks"
    @echo "==========================================="
    @echo ""
    @just setup-persistent
    @echo ""
    @just setup-platform
    @echo ""
    @just setup-staging
    @echo ""
    @echo "✨ Setup complete!"
    @echo ""
    @echo "📝 Next steps:"
    @echo "1. Verify resources in Azure Portal"
    @echo "2. Read README.md for usage instructions"
    @echo ""
    @echo "💡 To destroy staging resources and save costs:"
    @echo "   just destroy-staging"
    @echo ""

# Setup persistent stack (one-time)
setup-persistent:
    @echo "🔧 Creating persistent stack..."
    pulumi stack select persistent --create 2>/dev/null || pulumi stack select persistent
    @echo "✅ Persistent stack selected"
    @echo ""
    @echo "🚀 Deploying persistent infrastructure..."
    pulumi up --yes

# Setup platform stack (one-time)
setup-platform:
    @echo "🔧 Creating platform stack..."
    pulumi stack select platform --create 2>/dev/null || pulumi stack select platform
    @echo "✅ Platform stack selected"
    @echo ""
    @echo "🚀 Deploying platform infrastructure..."
    pulumi up --yes

# Setup staging stack
setup-staging:
    @echo "🔧 Creating staging stack..."
    pulumi stack select staging --create 2>/dev/null || pulumi stack select staging
    @echo "✅ Staging stack selected"
    @echo ""
    @echo "🚀 Deploying staging infrastructure..."
    pulumi up --yes

# Setup production stack
setup-production:
    @echo "🔧 Creating production stack..."
    pulumi stack select production --create 2>/dev/null || pulumi stack select production
    @echo "✅ Production stack selected"
    @echo ""
    @echo "🚀 Deploying production infrastructure..."
    pulumi up --yes

# Deploy to staging
deploy-staging:
    @echo "🚀 Deploying to staging..."
    pulumi stack select staging
    pulumi up

# Deploy to production
deploy-production:
    @echo "🚀 Deploying to production..."
    pulumi stack select production
    pulumi up

# Preview staging changes
preview-staging:
    @echo "👀 Previewing staging changes..."
    pulumi stack select staging
    pulumi preview

# Preview production changes
preview-production:
    @echo "👀 Previewing production changes..."
    pulumi stack select production
    pulumi preview

# Destroy staging stack (cost savings)
destroy-staging:
    @echo "💰 Destroying staging infrastructure to save costs..."
    pulumi stack select staging
    pulumi destroy

# Destroy production stack (careful!)
destroy-production:
    @echo "⚠️  WARNING: Destroying production infrastructure!"
    @echo "Press Ctrl+C to cancel or Enter to continue..."
    @read
    pulumi stack select production
    pulumi destroy

# Show staging outputs
outputs-staging:
    @echo "📊 Staging outputs:"
    pulumi stack select staging
    pulumi stack output

# Show production outputs
outputs-production:
    @echo "📊 Production outputs:"
    pulumi stack select production
    pulumi stack output

# Show persistent outputs
outputs-persistent:
    @echo "📊 Persistent outputs:"
    pulumi stack select persistent
    pulumi stack output

# Show platform outputs
outputs-platform:
    @echo "📊 Platform outputs:"
    pulumi stack select platform
    pulumi stack output

# Check pulumi installation
check:
    @echo "🔍 Checking prerequisites..."
    @command -v pulumi >/dev/null 2>&1 || { echo "❌ Pulumi is not installed. Please install it first."; exit 1; }
    @command -v az >/dev/null 2>&1 || { echo "❌ Azure CLI is not installed. Please install it first."; exit 1; }
    @echo "✅ All prerequisites are installed"
    @echo ""
    @echo "Azure CLI status:"
    @az account show --query "{Subscription:name, User:user.name}" -o table || echo "Not logged in. Run 'az login'"
